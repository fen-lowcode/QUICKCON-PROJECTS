// ------------------- Login Window -------------------
int main()
{
    nana::form login_win(nana::API::make_center(400, 250));
    login_win.caption("Employee Login");

    nana::label user_label(login_win, "Username:");
    user_label.move(50, 50);
    user_label.size({80, 25});

    nana::textbox username(login_win);
    username.move(150, 50);
    username.size({200, 25});

    nana::label pass_label(login_win, "Password:");
    pass_label.move(50, 100);
    pass_label.size({80, 25});

    nana::textbox password(login_win);
    password.move(150, 100);
    password.size({200, 25});
    password.multi_lines(false);
    password.mask('*');

    nana::label message(login_win, "");
    message.move(50, 150);
    message.size({300, 25});

    nana::button login_button(login_win, "Login");
    login_button.move(150, 180);
    login_button.size({100, 30});

    login_button.events().click([&] {
        std::string user_text = username.text();
        std::string pass_text = password.text();

        if (authenticate(user_text, pass_text)) {
            login_win.close();       // Close login window
            show_employee_table();   // Show employee table
        } else {
            message.caption("Login Failed! Check your credentials.");
            message.fgcolor(nana::colors::red);
        }
    });

    login_win.show();
    nana::exec();
}

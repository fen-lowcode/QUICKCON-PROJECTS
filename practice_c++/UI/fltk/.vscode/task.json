{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build wxLoginApp",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-Wall",
                "-Wextra",
                "-g",
                "${workspaceFolder}/main.cpp",
                "`wx-config --cxxflags --libs`",
                "-o",
                "${workspaceFolder}/wxLoginApp"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}